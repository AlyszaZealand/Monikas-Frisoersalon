<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.monikasfrisoersalon.View.Controller.EmployeeController">
<children>

    <Label fx:id="usernameText" layoutX="20.0" layoutY="20.0" text="Logget ind som: ">
        <font>
            <Font name="System Bold" size="18.0" />
        </font>
    </Label>
    <Button fx:id="logoutButton" layoutX="860.0" layoutY="18.0" mnemonicParsing="false" onAction="#onLogout" text="Log ud" />

    <TableView fx:id="appointmentTable" layoutX="20.0" layoutY="60.0" prefHeight="500.0" prefWidth="650.0">
        <columns>
            <TableColumn fx:id="startDateColumn" prefWidth="120.0" text="Start tid" />
            <TableColumn fx:id="endDateColumn" prefWidth="120.0" text="Slut tid" />
            <TableColumn fx:id="customerColumn" prefWidth="110.0" text="Kunde" />
            <TableColumn fx:id="employeeColumn" prefWidth="100.0" text="Medarbejder" />
            <TableColumn fx:id="treatmentColumn" prefWidth="125.0" text="Behandling" />
            <TableColumn fx:id="statusColumn" prefWidth="73.0" text="Status" />
        </columns>
    </TableView>

    <VBox layoutX="690.0" layoutY="60.0" prefHeight="500.0" prefWidth="230.0" spacing="12.0">
        <children>
            <Label text="Aftale detaljer">
                <font>
                    <Font name="System Bold" size="16.0" />
                </font>
            </Label>

            <VBox spacing="2.0">
                <Label text="Kundenavn:" />
                <TextField fx:id="customerNameField" promptText="F.eks. Jens Jensen" />
            </VBox>

            <VBox spacing="2.0">
                <Label text="Telefonnummer:" />
                <TextField fx:id="customerPhoneField" promptText="F.eks. 12345678" />
            </VBox>

            <VBox spacing="2.0">
                <Label text="Dato:" />
                <DatePicker fx:id="appointmentDatePicker" prefWidth="240.0" />
            </VBox>

            <VBox spacing="2.0">
                <Label text="Tidspunkt (HH:mm):" />
                <TextField fx:id="appointmentTimeField" promptText="F.eks. 10:30" />
            </VBox>

            <VBox spacing="2.0">
                <Label text="Behandling:" />
                <ComboBox fx:id="treatmentComboBox" prefWidth="240.0" promptText="Vælg behandling" />
            </VBox>

            <VBox spacing="10.0">
                <padding>
                    <Insets top="15.0" />
                </padding>
                <Button fx:id="addAppointment" mnemonicParsing="false" onAction="#onAddAppointment" prefWidth="240.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Opret ny aftale" />
                <Button fx:id="editAppointment" mnemonicParsing="false" onAction="#onEditAppointment" prefWidth="240.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;" text="Rediger valgt aftale" />
                <Button fx:id="deleteAppointment" mnemonicParsing="false" onAction="#onDeleteAppointment" prefWidth="240.0" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold;" text="Aflys valgt aftale" />
                <Button fx:id="anonymizeCustomerButton" mnemonicParsing="false" onAction="#onAnonymizeCustomer" prefWidth="240.0" style="-fx-background-color: #ff9800; -fx-text-fill: white; -fx-font-weight: bold;" text="Anonymiser Kunde (GDPR)" />
            </VBox>
        </children>
    </VBox>

</children>
</AnchorPane>